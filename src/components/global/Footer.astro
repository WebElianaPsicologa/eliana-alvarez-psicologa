---
import { COMPANY_INFO } from "@/config/seoConf";
import { Image } from "astro:assets";
import Logo from "@/assets/images/logowhite256x128.png";
import LogoShine from "@/assets/icons/logoshinewhitecharacters.svg";
import InstagramIcon from "@/assets/icons/instagram.svg";
import YoutubeIcon from "@/assets/icons/youtube.svg";
import ArrowUpIcon from "@/assets/icons/arrow-up.svg";
import WhatsappIcon from "@/assets/icons/whatsapp.svg";
---

<footer class="bg-purple-dark px-6 py-4 md:px-12 lg:rounded-t-full lg:px-20">
  <div class="mx-auto max-w-7xl">
    <!-- Top section: Brand + Social -->
    <div class="flex items-center justify-center">
      <button
        id="back-button"
        type="button"
        class="text-soft-bg border-gray-lavender/20 hover:border-gray-lavender cursor-pointer rounded-lg border px-2 py-1 font-bold transition-all duration-300"
      >
        Volver Arriba <ArrowUpIcon
          class="inline-block h-4 w-4 animate-bounce"
        />
      </button>
    </div>
    <div
      class="border-soft-bg/20 flex flex-col items-center justify-between gap-6 border-b px-6 pb-5 md:flex-row"
    >
      <!-- Brand -->
      <div class="flex items-center">
        <a href="/" aria-label="Home">
          <Image src={Logo} alt="Logo" class="h-16 w-auto" />
        </a>
      </div>

      <!-- Social Media Icons -->
      <div class="flex items-center gap-5">
        {
          COMPANY_INFO.socialMedia.instagram && (
            <a
              href={COMPANY_INFO.socialMedia.instagram}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="text-soft-bg hover:text-gray-lavender transition-all duration-300 hover:scale-110"
            >
              <InstagramIcon class="h-7 w-7" />
            </a>
          )
        }
        {
          COMPANY_INFO.socialMedia.youtube && (
            <a
              href={COMPANY_INFO.socialMedia.youtube}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Youtube"
              class="text-soft-bg hover:text-gray-lavender transition-all duration-300 hover:scale-110"
            >
              <YoutubeIcon class="h-8 w-8" />
            </a>
          )
        }
        {
          COMPANY_INFO.socialMedia.whatsapp && (
            <a
              href={COMPANY_INFO.socialMedia.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Whatsapp"
              class="text-soft-bg hover:text-gray-lavender transition-all duration-300 hover:scale-110"
            >
              <WhatsappIcon class="h-6 w-6" />
            </a>
          )
        }
      </div>
    </div>

    <!-- Bottom section: Navigation + Copyright -->
    <a
      href="https://shineagencia.com/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Shine Agencia"
      class="flex items-center justify-center"
    >
      <p class="text-soft-bg text-xs">Creado por:</p>
      <Image src={LogoShine} alt="Logo" class="h-8 w-auto" />
    </a>

    <div
      class="flex flex-col items-center justify-between space-y-4 md:flex-row md:space-y-0"
    >
      <div class="text-soft-bg font-nunito text-center text-xs md:text-left">
        <small
          >&copy; {new Date().getFullYear()}
          {COMPANY_INFO.name}. Todos los derechos reservados.</small
        >
      </div>
      <div class="flex space-x-6 text-xs">
        <a
          href="/politica-de-privacidad"
          class="text-soft-bg hover:text-olive transition-colors duration-300"
        >
          <small>Política de Privacidad </small>
        </a>
        <a
          href="/terminos-y-condiciones"
          class="text-soft-bg hover:text-olive transition-colors duration-300"
        >
          <small>Términos y Condiciones</small>
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  const backBtn = document.querySelector("#back-button") as HTMLButtonElement;

  backBtn.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });
</script>
