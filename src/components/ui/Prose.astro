<div
  class="prose prose-lg prose-headings:text-purple-dark prose-p:text-purple-accent prose-p:text-justify prose-li:text-purple-accent/70 prose-td:text-purple-accent/70 prose-a:text-purple-accent prose-a:font-bold prose-a:hover:text-purple-dark prose-a:tracking-normal prose-strong:text-purple-dark prose-code:text-purple-accent prose-img:rounded-lg prose-img:object-contain prose-img:h-64 prose-img:w-full max-w-none"
>
  <slot />
</div>

<script>
  document.querySelectorAll(".prose div[style]").forEach((div) => {
    if (
      div instanceof HTMLElement &&
      div.style.position === "relative" &&
      div.style.paddingBottom
    ) {
      div.classList.add("video-wrap");
      const iframe = div.querySelector("iframe");
      if (iframe instanceof HTMLIFrameElement) {
        iframe.classList.add("video-wrap-iframe");
      }
    }
  });
</script>

<style>
  .video-wrap {
    overflow: hidden;
    border-radius: 0.75rem;
  }
  .video-wrap-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>