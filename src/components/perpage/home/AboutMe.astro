---
import { Image } from "astro:assets";
import profile from "@/assets/images/profile.png";
import GlobeIcon from "@/assets/icons/globe.svg";
import CheckmarkIcon from "@/assets/icons/checkmark.svg";
import BrainIcon from "@/assets/icons/brain.svg";
---

<section class="about-hero bg-soft-beige py-16 lg:py-24">
  <div class="container mx-auto max-w-7xl px-6 lg:px-12">
    <h1
      class="text-purple-dark mb-8 text-center text-3xl font-bold md:text-5xl"
    >
      Sobre mí
    </h1>
    <div
      class="grid grid-cols-1 overflow-hidden rounded-2xl shadow-2xl lg:grid-cols-5 lg:grid-rows-4"
    >
      <!-- Image - full width on mobile, 2 columns on desktop -->
      <div class="lg:col-span-2 lg:row-span-4 lg:rounded-none">
        <Image
          src={profile}
          alt="Eliana Álvarez"
          class="h-full w-full rounded-t-2xl object-cover lg:rounded-none"
          priority
        />
      </div>
      <!-- Content - below image on mobile, 3 columns starting at col 3 on desktop -->
      <div
        class="bg-soft-bg py-8 lg:col-span-3 lg:col-start-3 lg:row-span-4 lg:pr-8"
      >
        <!-- Content -->
        <div
          id="content-about-me"
          class="group border-purple-dark relative flex flex-col items-center justify-center space-y-8 overflow-hidden border-l-0 px-4 lg:rounded-r-2xl lg:border-y-2 lg:border-r-2 lg:px-8 lg:pt-16"
        >
          <!-- Decorative element -->
          <div
            class="bg-soft-beige absolute -top-14 -right-16 h-40 w-40 rounded-full transition-all duration-300 ease-in-out group-hover:scale-110"
          >
          </div>
          <h1 id="title-name" class="text-4xl font-bold md:text-7xl">
            Eliana <span class="font-light italic">Álvarez</span>
          </h1>
          <p class="text-gray-lavender text-center text-base md:text-lg">
            Más de 20 años acompañando procesos de transformación.
          </p>
          <p class="text-purple-dark text-justify text-lg">
            Psicóloga clínica con una trayectoria forjada en la escucha profunda
            y la actualización constante. Mi formación pluralista (TCC,
            Humanismo y Sistémica) me permite diseñar un proceso a tu medida,
            respetando tu ritmo y tu verdad.
          </p>
          <div
            id="highlights"
            class="grid grid-cols-1 gap-4 py-4 md:grid-cols-3"
          >
            <!-- highlight1 -->
            <article
              class="bg-purple-accent/80 flex flex-col items-center justify-center rounded-lg p-2 backdrop-blur-sm"
            >
              <p class="text-soft-beige text-lg font-bold">+20 Años</p>
              <CheckmarkIcon
                class="bg-gray-lavender text-soft-beige h-6 w-6 rounded-full p-1"
              />
              <p class="text-soft-beige text-sm">De experiencia clinica</p>
            </article>
            <!-- highlight2 -->
            <article
              class="bg-purple-accent/80 flex flex-col items-center justify-center rounded-lg p-2 backdrop-blur-sm"
            >
              <p class="text-soft-beige text-lg font-bold">Atención Online</p>
              <GlobeIcon
                class="bg-gray-lavender text-soft-beige h-6 w-6 rounded-full p-1"
              />
              <p class="text-soft-beige text-sm">Sin fronteras geográficas</p>
            </article>
            <!-- highlight3 -->
            <article
              class="bg-purple-accent/80 flex flex-col items-center justify-center rounded-lg p-2 backdrop-blur-sm"
            >
              <p class="text-soft-beige text-lg font-bold">Enfoque Integral</p>
              <BrainIcon
                class="bg-gray-lavender text-soft-beige h-6 w-6 rounded-full p-1"
              />
              <p class="text-soft-beige text-sm">Adaptado a tus necesidades</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animateAboutMe } from "@/utils/animations/home/aboutMeAnimation";

  animateAboutMe();
</script>
