---
import { Image } from "astro:assets";
import landscapeImg from "@/assets/images/landscape.webp";
import ArrowRightIcon from "@/assets/icons/arrow-right.svg";
import ShieldIcon from "@/assets/icons/shield.svg";
---

<section class="hero-section bg-soft-bg relative min-h-screen overflow-hidden">
  <!-- Atmospheric background glows -->
  <div
    class="bg-blue-mist/20 pointer-events-none absolute -bottom-40 -left-40 h-96 w-96 rounded-full blur-3xl"
  >
  </div>
  <div
    class="bg-olive/10 pointer-events-none absolute -top-20 right-2/5 h-64 w-64 rounded-full blur-3xl"
  >
  </div>

  <div class="grid min-h-screen grid-cols-1 items-stretch md:grid-cols-12">
    <!-- LEFT: Content Panel -->
    <div
      class="relative z-10 col-span-1 flex flex-col justify-center px-8 pt-24 pb-24 md:col-span-7 md:pt-40 lg:px-16 xl:px-24"
    >
      <div class="mx-auto w-full max-w-2xl">
        <!-- Kicker -->
        <div class="hero-kicker mb-7 flex items-center gap-3 opacity-0">
          <div class="bg-gray-lavender/60 h-px w-10 shrink-0"></div>
          <span
            class="font-nunito text-gray-lavender text-xs font-semibold tracking-widest uppercase"
          >
            El primer paso hacia tu bienestar
          </span>
        </div>

        <!-- H1 -->
        <h1
          class="hero-title text-purple-accent mb-6 text-4xl leading-tight font-black tracking-tight opacity-0 md:text-5xl xl:text-6xl"
        >
          <span class="block">Sana tu historia</span>
          <span class="text-purple-dark block font-extrabold"
            >para vivir un presente</span
          >
          <span class="block">con libertad emocional.</span>
        </h1>

        <!-- Subtitle -->
        <p
          class="hero-subtitle text-purple-dark/75 mb-10 max-w-lg text-base leading-relaxed opacity-0 lg:text-lg"
        >
          Amplia experiencia acompañando a adultos, adolescentes y familias a sanar
          la ansiedad, superar duelos y reconstruir vínculos mediante una
          terapia integral, humana y sin fronteras.
        </p>

        <!-- CTAs -->
        <div class="hero-ctas flex flex-wrap items-center gap-4 opacity-0">
          <a
            href="/contacto"
            class="group bg-purple-accent hover:bg-purple-dark inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:shadow-md lg:text-base"
          >
            Da el primer paso hoy
            <ArrowRightIcon
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
            />
          </a>

          <a
            href="/sobre-mi"
            class="border-purple-accent/30 text-purple-accent hover:border-purple-accent hover:bg-purple-accent/5 inline-flex items-center rounded-full border px-7 py-3.5 text-sm font-semibold transition-all duration-300 lg:text-base"
          >
            Conoce mi enfoque clínico
          </a>
        </div>
      </div>
    </div>

    <!-- ── RIGHT: Image Panel ──────────────────────────────────── -->
    <div class="relative col-span-1 hidden md:col-span-5 md:block">
      <!-- Left-to-content blend gradient -->
      <div
        class="from-soft-bg via-soft-bg/50 absolute inset-0 z-10 bg-linear-to-r to-transparent"
      >
      </div>
      <!-- Bottom vignette -->
      <div
        class="from-soft-bg/30 absolute inset-x-0 bottom-0 z-10 h-48 bg-linear-to-t to-transparent"
      >
      </div>

      <Image
        src={landscapeImg}
        alt="Paisaje montañoso al atardecer: una persona de pie sobre una roca contempla el horizonte — símbolo de fortaleza y perspectiva personal en el proceso terapéutico"
        class="hero-image absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />
    </div>
  </div>

  <!-- Floating Experience Badge -->
  <div
    class="hero-badge absolute bottom-10 left-3/5 z-20 hidden -translate-x-1/2 md:invisible md:block lg:bottom-20"
  >
    <div
      class="bg-olive shadow-purple-dark/10 relative overflow-hidden rounded-2xl px-5 py-4 shadow-xl"
    >
      <!-- Decorative inner accent -->
      <div
        class="bg-purple-accent/10 absolute -top-4 -right-4 h-16 w-16 rounded-full"
      >
      </div>

      <div class="relative mb-1.5 flex items-end gap-0.5">
        <span
          class="font-jakarta text-purple-dark text-5xl leading-none font-black"
          >20</span
        >
        <span
          class="font-jakarta text-purple-dark mb-1 text-2xl leading-none font-black"
          >+</span
        >
      </div>
      <p
        class="text-purple-dark/65 relative text-xs leading-snug font-semibold tracking-wider uppercase"
      >
        <span class="block">Años de</span>
        <span class="block">experiencia clínica</span>
      </p>
    </div>
  </div>
</section>

<script>
  import { heroAnimations } from "@/utils/animations/home/hero.Animations.js";
  heroAnimations();
</script>
