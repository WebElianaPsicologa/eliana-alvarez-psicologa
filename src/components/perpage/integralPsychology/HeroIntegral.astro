---
import { getCldVideoUrl } from "astro-cloudinary/helpers";
import ArrowRightIcon from "@/assets/icons/arrow-right.svg";
import ShieldIcon from "@/assets/icons/shield.svg";

const videoOpts = {
  width: 1280,
  height: 960,
  format: "auto",
  quality: "auto",
};

const posterOpts = {
  width: 1280,
  height: 960,
  rawTransformations: ["so_auto", "f_webp", "q_auto"],
};

const heroVideo = getCldVideoUrl({
  src: "PROCESOPSICOLÓGICO_v2otp8",
  ...videoOpts,
});
const heroPoster = getCldVideoUrl({
  src: "PROCESOPSICOLÓGICO_v2otp8",
  ...posterOpts,
});

---

<section class="hero-integral bg-soft-bg relative overflow-hidden pb-16 pt-28 md:pb-24 md:pt-36 lg:pt-44">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2 lg:gap-16">

      <!-- LEFT: Content -->
      <div class="flex flex-col justify-center">

        <!-- Kicker -->
        <div class="hero-integral-kicker invisible mb-6 flex items-center gap-3">
          <div class="bg-gray-lavender/60 h-px w-10 shrink-0"></div>
          <span class="font-nunito text-gray-lavender text-xs font-semibold tracking-widest uppercase">
            Proceso Psicológico Integral
          </span>
        </div>

        <!-- H1 -->
        <h1
          class="hero-integral-title text-purple-accent invisible mb-6 text-4xl font-black leading-tight tracking-tight md:text-5xl xl:text-6xl"
        >
          <span class="block">Más que terapia:</span>
          <span class="text-purple-dark block font-extrabold">un camino de</span>
          <span class="block">crecimiento profundo.</span>
        </h1>

        <!-- Pill tag -->
        <div class="hero-integral-tags invisible mb-8">
          <span
            class="bg-olive/30 text-purple-dark border-olive/50 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold"
          >
            <span class="bg-purple-accent h-1.5 w-1.5 rounded-full"></span>
            Psicoterapia + Entrenamiento en Habilidades | 100% Online
          </span>
        </div>

        <!-- Subtitle -->
        <p class="hero-integral-subtitle text-purple-dark/75 invisible mb-10 max-w-md text-base leading-relaxed lg:text-lg">
          Un proceso terapéutico de mediano o largo plazo diseñado para ir a la
          raíz, fortalecer tu mundo emocional y entrenar las habilidades que
          necesitas para adaptarte a cualquier desafío.
        </p>

        <!-- CTAs -->
        <div class="hero-integral-ctas invisible flex flex-wrap items-center gap-4">
          <a
            href="/contacto"
            class="group bg-purple-accent hover:bg-purple-dark inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-semibold text-white shadow-sm transition-all duration-300 hover:shadow-md lg:text-base"
          >
            Quiero comenzar mi transformación
            <ArrowRightIcon class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" />
          </a>

          <a
            href="/sobre-mi"
            class="border-purple-accent/30 text-purple-accent hover:border-purple-accent hover:bg-purple-accent/5 inline-flex items-center rounded-full border px-7 py-3.5 text-sm font-semibold transition-all duration-300 lg:text-base"
          >
            Conoce el enfoque
          </a>
        </div>

        <!-- Microcopy -->
        <div class="hero-integral-microcopy invisible mt-5 flex items-center gap-2">
          <ShieldIcon class="text-gray-lavender h-3.5 w-3.5 shrink-0" />
          <span class="font-nunito text-gray-lavender text-xs">
            Atención confidencial vía Zoom / Microsoft Teams.
          </span>
        </div>
      </div>

      <!-- RIGHT: Video Card + Stats -->
      <div class="flex flex-col gap-6">

        <!-- Contained video card -->
        <div class="relative aspect-video overflow-hidden rounded-3xl shadow-xl">
          <video
            autoplay
            controls
            muted
            loop
            playsinline
            preload="auto"
            poster={heroPoster}
            class="hero-integral-image invisible absolute inset-0 h-full w-full object-cover object-center"
            aria-label="Proceso psicológico integral: autoconocimiento profundo para una transformación sostenible"
          >
            <source src={heroVideo} type="video/mp4" />
          </video>
        </div>

        <!-- Caption -->
        <div class="px-1">
          <p class="font-jakarta text-purple-dark text-sm font-semibold">
            Proceso psicológico integral
          </p>
          <p class="font-nunito text-purple-dark/50 mt-0.5 text-xs">
            Autoconocimiento profundo para una transformación sostenible
          </p>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  import { heroIntegralAnimations } from "@/utils/animations/integralPsychology/heroIntegral.Animations.js";
  heroIntegralAnimations();
</script>
