---

<section class="py-l6 mx-auto w-full px-6 lg:px-16 lg:py-24">
  <div class="mx-auto mt-12 max-w-7xl lg:mt-0">
    <!-- Kicker -->
    <div class="approach-kicker mb-12 flex items-center gap-3">
      <div class="bg-gray-lavender/50 h-px w-8 shrink-0"></div>
      <span
        class="font-nunito text-gray-lavender text-xs font-semibold tracking-widest uppercase"
      >
        Cómo trabajaremos
      </span>
    </div>
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-5">
      <!-- Left side heading -->
      <div class="col-span-2 lg:sticky lg:top-24 lg:self-start">
        <h2 class="text-purple-accent text-4xl font-bold uppercase">
          Un proceso breve, pero estructurado.
        </h2>
        <p class="text-purple-dark mt-6 text-lg">
          Cada sesión tiene un propósito claro. Avanzamos <span
            class="font-bold italic">juntos</span
          > desde la evaluación inicial hasta que te llevas herramientas concretas
          para aplicar en tu vida cotidiana.
        </p>
      </div>
      <!-- Right side content -->
      <div class="line-sections col-span-3">
        <!-- section 1 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">1</div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">Evaluación</h2>
            <p
              class="text-purple-dark/70 mt-2 text-sm font-semibold tracking-widest uppercase"
            >
              Sesión inicial
            </p>
            <p class="text-purple-dark mt-2 text-lg">
              Entendemos tu necesidad y definimos si requieres <span
                class="font-bold">Orientación Psicológica</span
              > o un programa de <span class="font-bold"
                >Desarrollo de Habilidades</span
              >.
            </p>
          </div>
        </div>
        <!-- section 2 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">2</div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">
              Estrategia y Desarrollo
            </h2>
            <p
              class="text-purple-dark/70 mt-2 text-sm font-semibold tracking-widest uppercase"
            >
              Sesiones intermedias
            </p>
            <p class="text-purple-dark mt-2 text-lg">
              Aplicamos pruebas, ejercicios prácticos o pautas de conducta según
              tu plan personalizado.
            </p>
          </div>
        </div>
        <!-- section 3 -->
        <div
          class="line-section border-gray-lavender/20 flex items-center border-y p-8"
        >
          <div class="text-purple-accent text-4xl font-bold lg:text-9xl">3</div>
          <div
            class="line-holder bg-gray-lavender/20 h-36 w-5 overflow-hidden rounded-xl"
          >
            <div class="line bg-purple-accent h-24 w-full rounded-xl"></div>
          </div>
          <div class="text-purple-dark ml-8 max-w-lg">
            <h2 class="text-purple-accent text-2xl font-bold">
              Cierre y Plan de Acción
            </h2>
            <p
              class="text-purple-dark/70 mt-2 text-sm font-semibold tracking-widest uppercase"
            >
              Sesión final
            </p>
            <p class="text-purple-dark mt-2 text-lg">
              Te llevas herramientas sostenibles para aplicar en tu vida
              cotidiana sin depender de la consulta.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { eticPillarsAnimation } from "@/utils/animations/about/eticPillars.Animation";

  eticPillarsAnimation();
</script>
