          <div class="mt-5">
            <div class="flex flex-col items-start justify-center space-y-4">
              <!-- Section Label -->
              <div class="flex items-center justify-between">
                <BrainIcon class="text-purple-dark mr-4 h-6 w-6" />
                <h1
