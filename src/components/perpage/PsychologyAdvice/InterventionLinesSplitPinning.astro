          Lo que ofrezco
        </span>
        <div class="bg-gray-lavender/50 h-px w-8 shrink-0"></div>
      </div>
      <h2
        class="text-purple-accent mb-4 text-center text-4xl leading-tight font-bold lg:text-5xl"
      >
        Mis 3 Líneas de <span class="block">Intervención</span>
      </h2>
    </div>

    <!-- Gallery -->
    <div class="gallery flex gap-8">
      <!-- Left content -->
      <div class="left hidden w-1/2 lg:block">
        <div class="desktopContent m-auto w-full">
          <!-- First section: Orientación Psicológica -->
          <div
            class="desktopContentSection flex min-h-screen flex-col justify-center"
