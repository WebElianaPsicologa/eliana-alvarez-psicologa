<script>
  import { demolicionesServicesAnimationAll } from "@/utils/animations/psychologyAdvice/interventionLinesSplitPinning.Animation";

  // Desktop: lazy-inject <source> 300px before video enters the viewport.
  // The src doesn't exist in the HTML at all, so the browser makes zero
  // requests until this observer fires. unobserve() after loading since
  // GSAP takes over play/pause from here.
  const desktopLazyVideos = document.querySelectorAll<HTMLVideoElement>(
    ".desktopPhoto[data-src]",
  );

  // Track video readiness
  let firstVideoReady = false;
  const videoReadyPromises: Promise<void>[] = [];

  const desktopLazyObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const video = entry.target as HTMLVideoElement;
          const source = document.createElement("source");
          source.src = video.dataset.src!;
          source.type = "video/mp4";
          video.appendChild(source);
          video.load();
          desktopLazyObserver.unobserve(video);
        }
      });
    },
    { rootMargin: "300px" },
  );

  // Create promises for each video to track when they can play
  desktopLazyVideos.forEach((v, index) => {
    const promise = new Promise<void>((resolve) => {
      const handleCanPlay = () => {
        if (index === 0) firstVideoReady = true;
        v.removeEventListener("canplay", handleCanPlay);
        resolve();
      };
      v.addEventListener("canplay", handleCanPlay);
    });
    videoReadyPromises.push(promise);
    desktopLazyObserver.observe(v);
  });

  // Wait for first video to be ready before initializing GSAP animations
  // This prevents race condition where switchVideo(0) tries to play before load
  Promise.race([
    videoReadyPromises[0],
    new Promise((resolve) => setTimeout(resolve, 3000)), // fallback timeout
  ]).then(() => {
    demolicionesServicesAnimationAll();
  });

  // Mobile: play/pause based on viewport visibility (50% threshold).
  // preload="metadata" ensures first frame loads, preventing gray flash
  const mobileVideos =
    document.querySelectorAll<HTMLVideoElement>(".mobilePhoto");
  const mobileObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    },
    { threshold: 0.5 },
  );
  mobileVideos.forEach((v) => mobileObserver.observe(v));
</script>
