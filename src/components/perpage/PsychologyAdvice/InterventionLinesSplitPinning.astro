---
import { getCldVideoUrl } from "astro-cloudinary/helpers";
import CompassIcon from "@/assets/icons/compass.svg";
import BrainIcon from "@/assets/icons/brain-resistance.svg";
import UserIcon from "@/assets/icons/user.svg";
import PuzzleIcon from "@/assets/icons/puzzle.svg";
import CheckmarkIcon from "@/assets/icons/checkmark.svg";
import TalkIcon from "@/assets/icons/talk.svg";
import PuzzleItemIcon from "@/assets/icons/puzzle.svg";
import FamilyIcon from "@/assets/icons/family.svg";
import ClockIcon from "@/assets/icons/clock.svg";

const lines = [
  {
    icon: "compass",
    audiences: ["Individuos", "Parejas", "Familias"],
    title: "Orientación Psicológica",
    tagline: "Guía clara para situaciones específicas",
    sectionLabel: "El objetivo",
    body: "Si estás pasando por un conflicto puntual en casa, con tu pareja o en el trabajo y necesitas una \u201cbrújula\u201d externa. No indagamos en traumas antiguos, sino que resolvemos el nudo actual.",
    listLabel: "Lograrás",
    items: [
      "Estrategias para manejar situaciones difíciles del día a día",
      "Mejorar tu toma de decisiones inmediata",
      "Recuperar el bienestar integral ante un reto concreto",
    ],
    skillItems: null,
    achievement: null,
    methodology: null,
    sessions: "3 a 8 Sesiones",
  },
  {
    icon: "user",
    audiences: ["Jóvenes", "Adultos", "Profesionales"],
    title: "Orientación Vocacional & Profesional",
    tagline: "Diseña un futuro que te apasione",
    sectionLabel: "El proceso incluye",
    body: null,
    listLabel: null,
    items: [
      "Evaluación integral con pruebas especializadas (test de aptitudes e intereses)",
      "Análisis del mercado laboral actual",
      "Plan de acción: metas a corto, mediano y largo plazo",
    ],
    skillItems: null,
    achievement:
      "Construir un camino profesional alineado con tus talentos reales, no con las expectativas de otros.",
    methodology: null,
    sessions: "5 a 8 Sesiones",
  },
  {
    icon: "brain",
    audiences: ["Entrenamiento Psicoeducativo"],
    title: "Desarrollo de Habilidades",
    tagline: "Potencia tus fortalezas a través de la Psicoeducación",
    sectionLabel: "Áreas de entrenamiento",
    body: null,
    listLabel: null,
    items: null,
    skillItems: [
      { icon: "talk", label: "Comunicación Asertiva y Empatía" },
      { icon: "puzzle-item", label: "Resolución de Conflictos" },
      {
        icon: "brain-resistance",
        label: "Resiliencia e Inteligencia Emocional",
      },
      { icon: "family", label: "Pautas de Crianza efectivas" },
      {
        icon: "clock",
        label: "Gestión del tiempo y fin de la procrastinación",
      },
    ],
    achievement: null,
    methodology:
      "Práctica guiada, modelado de conductas y feedback constructivo en un entorno seguro.",
    sessions: "3 a 8 Sesiones",
  },
];

// Cloudinary video optimization
// format: "auto" → WebM (VP9) for Chrome/Firefox, MP4 (H.264) for Safari
// quality: "auto" → content-aware compression
const videoOpts = {
  width: 1280,
  height: 720,
  format: "auto",
  quality: "auto",
};

// Poster URLs: so_auto picks the most representative frame, f_webp outputs static image
const posterOpts = {
  width: 1280,
  height: 720,
  rawTransformations: ["so_auto", "f_webp", "q_auto"],
};

// TODO: Replace these placeholder video IDs with actual demoliciones footage
const orientacionPsicologicaVideo = getCldVideoUrl({
  src: "1_ORIENTACION_PSICOLOGICA_1_zn00ql",
  ...videoOpts,
});
const orientacionPsicologicaPoster = getCldVideoUrl({
  src: "1_ORIENTACION_PSICOLOGICA_1_zn00ql",
  ...posterOpts,
});

const orientacionVocacionalVideo = getCldVideoUrl({
  src: "2_ORIENTACION_VOCACIONAL_1_tnqrbe",
  ...videoOpts,
});
const orientacionVocacionalPoster = getCldVideoUrl({
  src: "2_ORIENTACION_VOCACIONAL_1_tnqrbe",
  ...posterOpts,
});

const desarrolloDeHabilidadesVideo = getCldVideoUrl({
  src: "3_DESARROLLO_DE_HABILIDADES_1_sghmqh",
  ...videoOpts,
});
const desarrolloDeHabilidadesPoster = getCldVideoUrl({
  src: "3_DESARROLLO_DE_HABILIDADES_1_sghmqh",
  ...posterOpts,
});
---

