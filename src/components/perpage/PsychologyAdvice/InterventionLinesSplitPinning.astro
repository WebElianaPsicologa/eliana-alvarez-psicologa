            class="mobilePhoto mt-10 size-[80vw] rounded-2xl object-cover"
            controls
            muted
            loop
            playsinline
            preload="metadata"
            poster={orientacionVocacionalPoster}
          >
            <source src={orientacionVocacionalVideo} type="video/mp4" />
          </video>
          <div class="mt-5">
            <div class="flex flex-col items-start justify-center space-y-4">
              <!-- Section Label -->
              <div class="flex items-center justify-between">
                <UserIcon class="text-purple-dark mr-4 h-6 w-6" />
                <h1
                  class="text-purple-dark text-shadow-purple-dark text-2xl font-bold text-shadow-xs"
                >
                  {lines[1]?.title}
                </h1>
              </div>
              <p class="text-purple-dark text-justify">
                {lines[1]?.tagline}
              </p>
              <div class="flex flex-col space-y-4">
                <h2 class="text-purple-dark text-2xl font-bold">
                  {lines[1]?.listLabel}
                </h2>
                <ul class="flex list-inside list-disc flex-wrap gap-3">
