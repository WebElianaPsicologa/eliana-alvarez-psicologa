---
import AlertTriangleIcon from "@/assets/icons/alert-triangle.svg";

const emergencyNumbers = [
  { country: "Colombia", number: "123" },
  { country: "Brasil", number: "188 / 192" },
  { country: "Global", number: "911" },
];
---

<div class="bg-soft-beige px-6 py-16">
  <div class="mx-auto max-w-4xl">
    <div
      class="border-purple-accent/20 bg-soft-bg relative overflow-hidden rounded-2xl border px-8 py-7"
    >
      <!-- Left accent bar -->
      <div
        class="bg-purple-accent absolute top-0 left-0 h-full w-1 rounded-l-2xl"
      >
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
        <!-- Warning icon -->
        <div class="shrink-0">
          <div
            class="border-purple-accent/30 bg-purple-accent/8 flex h-10 w-10 items-center justify-center rounded-full border"
          >
            <AlertTriangleIcon class="h-5 w-5 text-yellow-600" />
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1">
          <p
            class="text-purple-dark mb-1 text-sm font-bold tracking-wider uppercase"
          >
            Aviso importante
          </p>
          <p class="text-purple-dark/80 mb-4 text-sm leading-relaxed">
            Este formulario y el correo electrónico
            <strong class="text-purple-dark font-semibold">
              no son canales para la atención de emergencias o crisis suicidas.
            </strong>
            Si tu vida o la de alguien más corre peligro inmediato, por favor acude
            a la guardia médica más cercana o llama a los números de emergencia de
            tu país:
          </p>

          <!-- Emergency numbers -->
          <div class="flex flex-wrap gap-2">
            {
              emergencyNumbers.map((item) => (
                <div class="border-purple-accent/20 bg-purple-accent/5 flex items-center gap-2 rounded-full border px-4 py-1.5">
                  <span class="text-purple-accent/60 text-xs font-medium">
                    {item.country}
                  </span>
                  <span class="bg-purple-accent/20 h-3 w-px" />
                  <span class="text-purple-dark text-sm font-bold tracking-wide">
                    {item.number}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
